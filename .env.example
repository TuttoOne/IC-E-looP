# Copier en .env et renseigner les vraies valeurs (non commité).

# https://app.fullenrich.com — clé API compte (même clé que l'extension fullenrich-extension)
FULLENRICH_API_KEY=

# CRM tsplus-outreach (backend FastAPI "TSplus Outreach"), joignable via Tailscale.
# Défaut: http://100.102.244.19:8221 (spark-e991). Auth = compte de service SANS 2FA.
CRM_API_BASE=http://100.102.244.19:8221
CRM_USERNAME=
CRM_PASSWORD=
# Optionnel: si défini, les prospects créés sont enrôlés dans cette séquence (send_mode=manual,
# rien n'est envoyé sans validation humaine). Vide = création du prospect uniquement.
CRM_SEQUENCE_ID=

# Sillage (getsillage.com) — clé API fournie par Sillage
SILLAGE_API_KEY=
SILLAGE_API_BASE=https://api.getsillage.com

# Anthropic — utilisé par l'Interrogation engine pour dialoguer sur l'ICP
ANTHROPIC_API_KEY=

# Managed Agents (front server.js) — ids créés dans la console Anthropic,
# même organisation que la clé API ci-dessus
AGENT_ID=
SCORING_AGENT_ID=
ENVIRONMENT_ID=
PORT=3010

