# Copier en .env et renseigner les vraies valeurs (non commité).

# https://app.fullenrich.com — clé API compte (même clé que l'extension fullenrich-extension)
FULLENRICH_API_KEY=

# HubSpot — token d'App privée (portail 1POINT6), scopes: crm.objects.contacts, crm.objects.companies, crm.objects.deals
HUBSPOT_PRIVATE_APP_TOKEN=

# Sillage (getsillage.com) — clé API fournie par Sillage
SILLAGE_API_KEY=
SILLAGE_API_BASE=https://api.getsillage.com

# Anthropic — utilisé par l'Interrogation engine pour dialoguer sur l'ICP
ANTHROPIC_API_KEY=

# Managed Agents (front server.js) — ids créés dans la console Anthropic,
# même organisation que la clé API ci-dessus
AGENT_ID=
SCORING_AGENT_ID=
PERSONA_AGENT_ID=
STAKEHOLDER_AGENT_ID=
CONTENT_LISTENER_AGENT_ID=
ENVIRONMENT_ID=
PORT=3010

